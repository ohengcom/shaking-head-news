# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional Microsoft Entra ID provider
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=common

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEWS_API_BASE_URL=https://news.ravelloh.top

# Optional default Pro grants
# Current product rule: any signed-in user can self-activate Pro.
# These two variables only seed default Pro status for specific users.
PRO_USER_IDS=
PRO_USER_EMAILS=

# Optional ads / logging
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_LOG_LEVEL=info
